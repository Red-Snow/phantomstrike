# PhantomStrike AI — Environment Configuration
# Copy this file to .env and modify as needed.

# ── Server ──────────────────────────────────────────────────────────────────
PHANTOMSTRIKE_HOST=127.0.0.1
PHANTOMSTRIKE_PORT=8443
PHANTOMSTRIKE_RELOAD=false

# ── Authentication ──────────────────────────────────────────────────────────
# Set to false to disable auth (development only!)
PHANTOMSTRIKE_AUTH_ENABLED=true
# Comma-separated API keys for authentication
# PHANTOMSTRIKE_API_KEYS=your-key-1,your-key-2
# Secret for JWT token signing (auto-generated if not set)
# PHANTOMSTRIKE_SECRET_KEY=your-secret-key

# ── Execution ───────────────────────────────────────────────────────────────
PHANTOMSTRIKE_MAX_JOBS=5
PHANTOMSTRIKE_TIMEOUT=600
PHANTOMSTRIKE_DOCKER_SANDBOX=false
PHANTOMSTRIKE_WORKSPACE=/tmp/phantomstrike

# ── Database ────────────────────────────────────────────────────────────────
# Default: SQLite in ~/.phantomstrike/phantomstrike.db
# PHANTOMSTRIKE_DB_URL=sqlite+aiosqlite:///path/to/db

# ── Logging ─────────────────────────────────────────────────────────────────
PHANTOMSTRIKE_LOG_LEVEL=INFO
# PHANTOMSTRIKE_LOG_FILE=/var/log/phantomstrike.log
